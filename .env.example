# 瓷砖SKU知识库采集系统 - 配置文件模板
# 复制为 .env 后填写API密钥

# 运行环境 (dev=开发, prod=生产)
ENV=dev

# 数据库: sqlite=本地文件(默认)  mysql=需MySQL/RDS
DB_TYPE=sqlite

# ── 阿里云自动化（7×24）────────────────────────
AUTO_INBOX_ENABLED=true
AUTO_INBOX_CRON_MINUTES=15
AUTO_CRAWL_WEB_ENABLED=false

# MySQL 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=tile123456
MYSQL_DATABASE=tile_ai

# Milvus 向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=tile_image_vector

# MinerU PDF解析 API
MINERU_API_URL=http://localhost:8888
MINERU_API_KEY=

# ── 大模型API配置（填任意一家即可使用） ──
# DeepSeek - 深度求索 (推荐，性价比高)
DEEPSEEK_API_KEY=
# 最新: deepseek-v4-flash / deepseek-v4-pro；兼容: deepseek-chat / deepseek-reasoner
DEEPSEEK_MODEL=deepseek-v4-flash

# 阿里云 - 通义千问 Qwen3
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen3-8b

# 智谱AI - ChatGLM
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash

# 月之暗面 - Kimi
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-8k

# 百川智能
BAICHUAN_API_KEY=
BAICHUAN_MODEL=Baichuan4

# MiniMax - 海螺AI
MINIMAX_API_KEY=
MINIMAX_MODEL=abab6.5s-chat

# 字节跳动 - 豆包
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-pro-32k

# 百度 - 千帆（文心一言）
QIANFAN_API_KEY=
QIANFAN_MODEL=ernie-speed

# ── 图片向量模型 ──────────────────────────────────────
OPENCLIP_MODEL=ViT-B-32
OPENCLIP_PRETRAINED=laion2b_s34b_b79k

# 爬虫设置
CRAWLER_HEADLESS=true
CRAWLER_DELAY_MIN=1
CRAWLER_DELAY_MAX=3

# 日志级别
LOG_LEVEL=INFO